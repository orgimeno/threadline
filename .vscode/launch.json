{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Threadline backend",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--env-file=.env",
        "--import",
        "tsx"
      ],
      "program": "${workspaceFolder}/backend/src/server.ts",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
